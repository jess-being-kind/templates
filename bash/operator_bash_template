#!/usr/bin/env bash
# operator_bash_template_v2_1_0.sh
#
# Purpose:
#   Generic Bash template for engineering/operator automation.
#
# Good for:
#   - setup scripts
#   - hardware runner scripts
#   - data collection wrappers
#   - file organization
#   - repeatable test commands
#
# Pattern:
#   parse_args -> validate_config -> run_workflow
#
# Operator rules:
#   - Dry-run is the default for risky actions.
#   - All side effects go through run_cmd/write_file.
#   - Quote variables unless you intentionally want word splitting.
#   - Use arrays for commands instead of eval.
#   - Keep main guarded so tests can source this file.

set -Eeuo pipefail
IFS=$'\n\t'

# =============================================================================
# S0. Metadata / globals
# =============================================================================

    VERSION="2.1.0"
    AUTHOR="V Halcyon"
    SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    RUN_ID="$(date -u +"%Y%m%d_%H%M%S_UTC")"

    APPLY=0                 # Default: dry-run. Use --apply to change the world.
    VERBOSE=0
    FORCE=0
    SELF_TEST=0
    INPUT_PATH=""
	ENGINEERING_DIR="${HOME}/Vec/Engineering"
	OUTPUT_DIR="${ENGINEERING_DIR}/active"
	
# =============================================================================
# S1. Logging / errors
# =============================================================================

    supports_color() { [[ -t 1 && "${NO_COLOR:-}" == "" ]]; }

    _color() {
        local code="$1"
        if supports_color; then printf '\033[%sm' "$code"; fi
        return 0
    }

    _reset() {
        if supports_color; then printf '\033[0m'; fi
        return 0
    }

    log()   { printf "%s[OK]%s %s\n" "$(_color '1;32')" "$(_reset)" "$*"; }
    info()  { printf "%s[INFO]%s %s\n" "$(_color '1;34')" "$(_reset)" "$*"; }
    warn()  { printf "%s[WARN]%s %s\n" "$(_color '1;33')" "$(_reset)" "$*" >&2; }
    err()   { printf "%s[ERR]%s %s\n" "$(_color '1;31')" "$(_reset)" "$*" >&2; }
    debug() {
        if (( VERBOSE )); then
            printf "%s[DEBUG]%s %s\n" "$(_color '0;36')" "$(_reset)" "$*" >&2
        fi
        return 0
    }

    die() { err "$*"; exit 1; }

    timestamp() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

    on_error() {
        local status=$?
        local line=${BASH_LINENO[0]:-unknown}
        err "Failed at line ${line} with status ${status}."
        exit "$status"
    }
    trap on_error ERR

    cleanup() {
        local status=$?
        if (( status == 0 )); then
            debug "Cleanup complete."
        else
            warn "Script exited with status ${status}."
        fi
    }
    trap cleanup EXIT

# =============================================================================
# S2. Small validation helpers
# =============================================================================

    require_command() {
        local cmd="$1"
        command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
    }

    assert_file_exists() {
        local path="$1"
        [[ -f "$path" ]] || die "Expected file does not exist: $path"
    }

    assert_dir_exists() {
        local path="$1"
        [[ -d "$path" ]] || die "Expected directory does not exist: $path"
    }

    is_positive_integer() { [[ "${1:-}" =~ ^[1-9][0-9]*$ ]]; }

    is_yes() {
        case "${1,,}" in
            y|yes|true|1|on) return 0 ;;
            *) return 1 ;;
        esac
    }

# =============================================================================
# S3. Path / file helpers
# =============================================================================

    ensure_dir() {
        local dir="$1"
        run_cmd mkdir -p "$dir"
    }

    backup_if_exists() {
        local path="$1"
        if [[ -e "$path" ]]; then
            local backup="${path}.bak.${RUN_ID}"
            warn "Backing up existing path: $path -> $backup"
            run_cmd cp -a "$path" "$backup"
        fi
    }

    write_file() {
        local path="$1"
        local content="$2"

        if [[ -e "$path" && "$FORCE" -ne 1 ]]; then
            warn "File exists, skipping: $path  Use --force to replace after backup."
            return 0
        fi

        ensure_dir "$(dirname "$path")"

        if [[ -e "$path" ]]; then
            backup_if_exists "$path"
        fi

        if (( APPLY )); then
            local tmp="${path}.tmp.$$"
            printf "%s" "$content" > "$tmp"
            mv "$tmp" "$path"
            log "Wrote $path"
        else
            printf "[DRY RUN] write %q\n" "$path"
        fi
    }

    append_file() {
        local path="$1"
        local content="$2"
        ensure_dir "$(dirname "$path")"
        if (( APPLY )); then
            printf "%s" "$content" >> "$path"
            log "Appended $path"
        else
            printf "[DRY RUN] append %q\n" "$path"
        fi
    }

# =============================================================================
# S4. Command execution
# =============================================================================

    run_cmd() {
        # Usage:
        #   run_cmd cp "$src" "$dst"
        #   local cmd=(python3 analyze.py --input "$INPUT_PATH")
        #   run_cmd "${cmd[@]}"
        if (( APPLY )); then
            debug "RUN: $(printf '%q ' "$@")"
            "$@"
        else
            printf "[DRY RUN] "
            printf "%q " "$@"
            printf "\n"
        fi
    }

    capture_cmd() {
        # Capture command output when the command has no side effects.
        # Do not use this for changes hidden behind command substitution.
        debug "CAPTURE: $(printf '%q ' "$@")"
        "$@"
    }

# =============================================================================
# S5. Text / list helpers
# =============================================================================

    join_by() {
        local delimiter="$1"
        shift || true
        local first=1
        local item
        for item in "$@"; do
            if (( first )); then
                printf "%s" "$item"
                first=0
            else
                printf "%s%s" "$delimiter" "$item"
            fi
        done
    }

    split_csv() {
        # Example:
        #   mapfile -t items < <(split_csv "alpha,beta,gamma")
        local csv="${1:-}"
        local item
        IFS=',' read -r -a _items <<< "$csv"
        for item in "${_items[@]}"; do
            item="${item#${item%%[![:space:]]*}}"  # trim leading spaces
            item="${item%${item##*[![:space:]]}}"  # trim trailing spaces
            [[ -n "$item" ]] && printf "%s\n" "$item"
        done
    }

# =============================================================================
# S6. Manifest / summary helpers
# =============================================================================

	make_run_manifest() {
		cat <<-MANIFEST
	version=$VERSION
	author=$AUTHOR
	run_id=$RUN_ID
	timestamp=$(timestamp)
	script=$SCRIPT_NAME
	script_dir=$SCRIPT_DIR
	input_path=$INPUT_PATH
	output_dir=$OUTPUT_DIR
	apply=$APPLY
	force=$FORCE
	verbose=$VERBOSE
	MANIFEST
	}

	write_summary() {
		local path="$1"
		local status="$2"
		local content
		content="$(cat <<-SUMMARY
	status=$status
	run_id=$RUN_ID
	timestamp=$(timestamp)
	output_dir=$OUTPUT_DIR
	SUMMARY
	)"
		write_file "$path" "$content"
	}

# =============================================================================
# S7. CLI
# =============================================================================

	usage() {
		cat <<-USAGE
	Usage: $SCRIPT_NAME [options]

	Options:
	--apply                 Actually perform actions. Default is dry-run.
	--dry-run               Print actions without changing anything.
	--input PATH            Optional input file or directory.
	--output-dir DIR        Output directory. Default: $OUTPUT_DIR
	--force                 Replace generated files after backing them up.
	-v, --verbose           Enable debug logging.
	--self-test             Run a smoke test in /tmp.
	--version               Print version.
	-h, --help              Show this help.

	Examples:
	$SCRIPT_NAME --input data/raw/example.csv
	$SCRIPT_NAME --apply --input data/raw/example.csv --output-dir output
	$SCRIPT_NAME --self-test

	Syntax crib:
	Array command:   cmd=(python3 script.py --input "$INPUT_PATH"); run_cmd "\${cmd[@]}"
	If test:         if [[ -f "$INPUT_PATH" ]]; then log "exists"; fi
	Loop files:      while IFS= read -r file; do echo "$file"; done < <(find . -type f)
	Arithmetic:      if (( count > 3 )); then warn "large"; fi
	Case matching:   case "$arg" in start|stop) ;; *) die "bad" ;; esac
	USAGE
	}

	parse_args() {
		while (($#)); do
			case "$1" in
				--apply) APPLY=1 ;;
				--dry-run|--no-load-run) APPLY=0 ;;
				--input)
					shift || die "Missing value for --input"
					INPUT_PATH="${1:?missing value for --input}"
					;;
				--output-dir)
					shift || die "Missing value for --output-dir"
					OUTPUT_DIR="${1:?missing value for --output-dir}"
					;;
				--force) FORCE=1 ;;
				-v|--verbose) VERBOSE=1 ;;
				--self-test) SELF_TEST=1 ;;
				--version) printf "%s\n" "$VERSION"; exit 0 ;;
				-h|--help) usage; exit 0 ;;
				*) die "Unknown argument: $1" ;;
			esac
			shift
		done
	}

	validate_config() {
		[[ -n "$OUTPUT_DIR" ]] || die "--output-dir cannot be empty"

		if [[ -n "$INPUT_PATH" ]]; then
			[[ -e "$INPUT_PATH" ]] || die "--input does not exist: $INPUT_PATH"
		else
			warn "No --input provided; continuing with template behavior."
		fi

		# Add mission-specific requirements here, for example:
		# require_command jq
		# require_command mpremote
		# [[ -n "$INPUT_PATH" ]] && assert_file_exists "$INPUT_PATH"
	}

# =============================================================================
# S8. Workflow
# =============================================================================

	run_workflow() {
		info "Starting workflow"
		info "Run ID: $RUN_ID"

		ensure_dir "$ENGINEERING_DIR"
		ensure_dir "$OUTPUT_DIR"
		ensure_dir "$OUTPUT_DIR/logs"
		ensure_dir "$OUTPUT_DIR/artifacts"

		local manifest_path="$OUTPUT_DIR/logs/run_manifest_${RUN_ID}.txt"
		write_file "$manifest_path" "$(make_run_manifest)"

		# Replace this section with the actual mission.
		# Examples:
		#   run_cmd cp "$INPUT_PATH" "$OUTPUT_DIR/artifacts/"
		#   cmd=(python3 analyze.py --input "$INPUT_PATH" --output-dir "$OUTPUT_DIR")
		#   run_cmd "${cmd[@]}"
		#   run_cmd mpremote cp firmware/main.py :/main.py
		#   run_cmd bash -lc "printf 'avoid bash -lc for user input; this is only a known-safe example'"

		local summary_path="$OUTPUT_DIR/logs/summary_${RUN_ID}.txt"
		write_summary "$summary_path" "ok"

		log "Template workflow complete"
	}

	run_self_test() {
		local tmp_dir
		tmp_dir="$(mktemp -d)"
		info "Self-test temp dir: $tmp_dir"

		# Self-test intentionally uses --apply inside /tmp only.
		local old_apply="$APPLY"
		local old_output="$OUTPUT_DIR"
		APPLY=1
		OUTPUT_DIR="$tmp_dir/output"
		INPUT_PATH=""

		validate_config
		run_workflow

		assert_file_exists "$OUTPUT_DIR/logs/run_manifest_${RUN_ID}.txt"
		assert_file_exists "$OUTPUT_DIR/logs/summary_${RUN_ID}.txt"

		APPLY="$old_apply"
		OUTPUT_DIR="$old_output"
		rm -rf "$tmp_dir"
		log "Self-test passed"
	}

# =============================================================================
# S8. Main
# =============================================================================

	main() {
		parse_args "$@"
		if (( SELF_TEST )); then
			run_self_test
		else
			validate_config
			run_workflow
		fi
	}

	# Main guard: lets tests source this file without executing main.
	if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
		main "$@"
	fi
