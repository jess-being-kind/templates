setup_groups(){
  # Serial/I2C permissions are useful for microcontrollers and bench hardware.
  # This is intentionally optional-ish: usermod requires re-login and may fail in
  # containers, weird managed laptops, or locked-down systems.
  local target_user
  target_user="${USER:-$(id -un 2>/dev/null || true)}"
  if [[ -z "$target_user" ]]; then
    warn "Could not determine current username; skipping dialout/i2c group setup."
    return 0
  fi

  if (( APPLY )); then
    if have_cmd sudo; then
      info "Adding user to dialout and i2c groups when available"
      getent group dialout >/dev/null 2>&1 && run_optional sudo usermod -aG dialout "$target_user"
      getent group i2c >/dev/null 2>&1 && run_optional sudo usermod -aG i2c "$target_user"
    else
      warn "sudo not found; skipping dialout/i2c group setup."
    fi
  else
    echo "[DRY RUN optional] sudo usermod -aG dialout/i2c $target_user"
  fi
  return 0
}

