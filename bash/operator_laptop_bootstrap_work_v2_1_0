#!/usr/bin/env bash
# operator_laptop_bootstrap_v2.1.0.sh
#
# Mint/Ubuntu-style operator laptop bootstrap.
#
# Design rules:
#   - Dry-run by default. Nothing changes unless you pass --apply.
#   - Safe on a partially configured home laptop.
#   - Existing generated config files are skipped unless --force is passed.
#   - Existing files are backed up before replacement when --force is used.
#   - Engineering workspace lives under ~/Vec/Engineering, but folder names stay normal.
#   - Halcyon dark color tokens are written once and reused by shell, Terminator,
#     GTK/app preferences, matplotlib, Obsidian snippets, and optional VS Code config.
#
# Example:
#   bash operator_laptop_bootstrap_v2.1.0.sh
#   bash operator_laptop_bootstrap_v2.1.0.sh --apply --no-install
#   bash operator_laptop_bootstrap_v2.1.0.sh --apply --force

set -euo pipefail
IFS=$'\n\t'

# ==============================================================================
# S0: Metadata + default configuration
# ==============================================================================

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUN_ID="$(date +"%Y%m%d_%H%M%S")"

AUTHOR="V Halcyon"
VERSION="2.1.0"

# Dry-run by default.
APPLY=0
FORCE=0
VERBOSE=0

# Install toggles.
DO_INSTALL=1
INSTALL_OBSIDIAN=1
APPLY_SYSTEM_THEME=1
SET_VSCODE_USER_SETTINGS=1
VEC_ROOT_CUSTOM=1
VAULT_CUSTOM=1
ENGINEERING_CUSTOM=1

# User-tunable roots.
# Vec is the top-level home base; engineering folders under it keep normal names.
VEC_ROOT="${VEC_ROOT:-$HOME/Vec}"
VAULT_DIR="${VAULT_DIR:-$VEC_ROOT/Vaults/Work}"
ENGINEERING_DIR="${ENGINEERING_DIR:-$VEC_ROOT/Engineering}"

# Common managed paths.
LOCAL_BIN="$HOME/.local/bin"
HALCYON_CONFIG_DIR="$HOME/.config/halcyon"
MANIFEST_DIR="$ENGINEERING_DIR/logs/bootstrap"

# Halcyon dark palette: soot / amber / signal-blue / moss green.
# Canonical names are the aesthetic tokens; compatibility aliases keep older
# config writers working without rewriting every downstream template.
HALCYON_SOOT="#07090D"
HALCYON_SOOT_ALT="#0B1118"
HALCYON_PANEL="#11151C"
HALCYON_TEXT="#F2E8D5"
HALCYON_MUTED="#9AA0AA"
HALCYON_AMBER="#FFBF00"
HALCYON_BRASS="#B88746"
HALCYON_SIGNAL_BLUE="#4FA3B8"
HALCYON_MOSS="#8FA37A"
HALCYON_RUST="#B7410E"
HALCYON_MAROON="#6E2F35"
HALCYON_CYAN="#76B7B2"
HALCYON_PURPLE="#A77BD4"

# Compatibility aliases used by existing generated configs.
HALCYON_BG="$HALCYON_SOOT"
HALCYON_BG_ALT="$HALCYON_SOOT_ALT"
HALCYON_FG="$HALCYON_TEXT"
HALCYON_GOLD="$HALCYON_AMBER"
HALCYON_RED="$HALCYON_RUST"
HALCYON_GREEN="$HALCYON_MOSS"
HALCYON_BLUE="$HALCYON_SIGNAL_BLUE"

# ==============================================================================
# S1: Small logging and safety helpers
# ==============================================================================

log()   { printf "\033[1;32m[OK]\033[0m %s\n" "$*"; }
info()  { printf "\033[1;34m[INFO]\033[0m %s\n" "$*"; }
warn()  { printf "\033[1;33m[WARN]\033[0m %s\n" "$*"; }
err()   { printf "\033[1;31m[ERR]\033[0m %s\n" "$*" >&2; }
debug() { if (( VERBOSE )); then printf "\033[0;36m[DEBUG]\033[0m %s\n" "$*"; fi; return 0; }

die() { err "$*"; exit 1; }
stamp(){ date +"%Y%m%d_%H%M%S"; }
timestamp(){ date +"%Y-%m-%dT%H:%M:%S%z"; }

# run: the main side-effect gate. In dry-run mode it prints the command instead
# of executing it. Keep side effects behind this unless a command must be handled
# specially, like appending to a file.
run(){
  if (( APPLY )); then
    debug "RUN: $*"
    "$@"
  else
    printf '[DRY RUN] '
    printf '%q ' "$@"
    printf '\n'
  fi
}

# run_optional: same idea as run, but failures are warnings instead of fatal.
# Useful for desktop/theme commands that may not exist on every Mint/Ubuntu setup.
run_optional(){
  if (( APPLY )); then
    debug "TRY: $*"
    "$@" || warn "Optional command failed or is unsupported: $*"
  else
    printf '[DRY RUN optional] '
    printf '%q ' "$@"
    printf '\n'
  fi
}

ensure_dir(){
  # Creates a directory only through the run gate.
  local dir="$1"
  run mkdir -p "$dir"
}

backup_if_exists(){
  # Back up an existing file/path before replacing it.
  local path="$1"
  if [[ -e "$path" || -L "$path" ]]; then
    local backup="${path}.bak.$(stamp)"
    warn "Backing up existing path: $path -> $backup"
    run cp -a "$path" "$backup"
  fi
}

write_file(){
  # Write a managed file.
  # Safety behavior:
  #   - If the file exists and --force is not set, skip it.
  #   - If the file exists and --force is set, back it up first.
  local path="$1"
  local content="$2"

  ensure_dir "$(dirname "$path")"

  if [[ -e "$path" && "$FORCE" -ne 1 ]]; then
    warn "Exists, skipping: $path  Use --force to replace."
    return 0
  fi

  if [[ -e "$path" ]]; then
    backup_if_exists "$path"
  fi

  if (( APPLY )); then
    printf '%s' "$content" > "$path"
    log "Wrote $path"
  else
    echo "[DRY RUN] write $path"
  fi
}

write_file_stream(){
  # Read file content from stdin and pass it to write_file.
  # This keeps generated config files readable and avoids quoting accidents.
  local path="$1"
  local content
  content="$(cat)"
  write_file "$path" "$content"$'
'
}

append_once(){
  # Append a line to a file only if it is not already present.
  # This is how we safely modify ~/.bashrc on a laptop that already has setup.
  local path="$1"
  local marker="$2"
  local line="$3"

  ensure_dir "$(dirname "$path")"

  if [[ -f "$path" ]] && grep -Fq "$marker" "$path"; then
    log "$path already contains: $marker"
    return 0
  fi

  if (( APPLY )); then
    printf '\n%s\n%s\n' "$marker" "$line" >> "$path"
    log "Appended to $path: $marker"
  else
    echo "[DRY RUN] append to $path: $marker"
  fi
}

have_cmd(){ command -v "$1" >/dev/null 2>&1; }

# ==============================================================================
# S2: CLI options
# ==============================================================================

usage(){ cat <<EOF
Usage: bash $SCRIPT_NAME [options]

Operator laptop bootstrap v$VERSION.
Dry-run by default. Use --apply to make changes.

Options:
  --apply                 Actually make changes. Default is dry-run.
  --dry-run               Print actions without changing anything.
  --force                 Replace generated config files after making backups.
  --no-install            Skip apt/flatpak install steps.
  --no-obsidian           Skip Obsidian Flatpak install.
  --no-system-theme       Skip live gsettings theme changes; still writes config files.
  --no-vscode-user        Do not write ~/.config/Code/User/settings.json.
  --vec-root DIR          Top-level Vec directory. Default: $VEC_ROOT
  --vault DIR             Vault path. Default: $VAULT_DIR
  --engineering DIR       Engineering dir. Default: $ENGINEERING_DIR
  -v, --verbose           Enable debug logging.
  -h, --help              Show help.

Examples:
  bash $SCRIPT_NAME
  bash $SCRIPT_NAME --apply --no-install
  bash $SCRIPT_NAME --apply --force
  bash $SCRIPT_NAME --apply --vec-root "\$HOME/Vec"
EOF
}

parse_args(){
  while (($#)); do
    case "$1" in
      --apply) APPLY=1 ;;
      --dry-run) APPLY=0 ;;
      --force) FORCE=1 ;;
      --no-install) DO_INSTALL=0 ;;
      --no-obsidian) INSTALL_OBSIDIAN=0 ;;
      --no-system-theme) APPLY_SYSTEM_THEME=0 ;;
      --no-vscode-user) SET_VSCODE_USER_SETTINGS=0 ;;
      --vec-root) shift; VEC_ROOT="${1:?missing path}"; VEC_ROOT_CUSTOM=1 ;;
      --vault) shift; VAULT_DIR="${1:?missing path}"; VAULT_CUSTOM=1 ;;
      --engineering) shift; ENGINEERING_DIR="${1:?missing path}"; ENGINEERING_CUSTOM=1 ;;
      -v|--verbose) VERBOSE=1 ;;
      -h|--help) usage; exit 0 ;;
      *) err "Unknown option: $1"; usage; exit 1 ;;
    esac
    shift
  done

  # Recompute derived paths after CLI overrides.
  # If only --vec-root is changed, keep engineering/vault under that new root.
  if (( VEC_ROOT_CUSTOM )) && (( ! ENGINEERING_CUSTOM )); then
    ENGINEERING_DIR="$VEC_ROOT/Engineering"
  fi
  if (( VEC_ROOT_CUSTOM )) && (( ! VAULT_CUSTOM )); then
    VAULT_DIR="$VEC_ROOT/Vaults/Work"
  fi
  LOCAL_BIN="$HOME/.local/bin"
  HALCYON_CONFIG_DIR="$HOME/.config/halcyon"
  MANIFEST_DIR="$ENGINEERING_DIR/logs/bootstrap"
}

