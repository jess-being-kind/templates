echo "Done. Re-run with --apply to move files." >&2
'

  # Make generated helpers executable when applying.
  run chmod +x "$LOCAL_BIN/operator-status" "$LOCAL_BIN/vecbin" "$LOCAL_BIN/csvpeek" "$LOCAL_BIN/cleanup-downloads"
}

