# ==============================================================================
# S4: Package installation
# ==============================================================================

install_packages(){
  if (( ! DO_INSTALL )); then
    warn "Skipping package installation."
    return 0
  fi

  if ! have_cmd apt; then
    warn "apt not found; skipping package installation."
    return 0
  fi

  # Practical operator package set: coding, search, terminals, hardware, sensors,
  # file management, clipboard, and troubleshooting basics.
  local packages=(
    build-essential git curl wget ca-certificates gnupg unzip zip tree
    htop btop jq ripgrep fd-find fzf tmux terminator shellcheck
    python3 python3-pip python3-venv python3-serial python3-tk
    usbutils pciutils i2c-tools lm-sensors stress s-tui flatpak copyq
    ncdu xclip xsel flameshot pavucontrol gnome-disk-utility moreutils rename
  )

  info "Installing core packages"
  run sudo apt update
  run sudo apt install -y "${packages[@]}"

  if (( INSTALL_OBSIDIAN )); then
    info "Installing Obsidian using Flatpak/Flathub"
    run flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
    run flatpak install -y flathub md.obsidian.Obsidian
  else
    warn "Skipping Obsidian install."
  fi
}

