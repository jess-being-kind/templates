    raise SystemExit(1)

with path.open(newline="", encoding="utf-8", errors="replace") as f:
    reader = csv.reader(f)
    rows = []
    for i, row in enumerate(reader):
        rows.append(row)
        if i >= 5:
            break

print(f"File: {path}")
print(f"Size: {path.stat().st_size:,} bytes")
if not rows:
    print("Empty file")
    raise SystemExit(0)
cols = ", ".join(rows[0])
print(f"Columns ({len(rows[0])}): {cols}")
print("Preview:")
for row in rows[1:]:
    print("  " + " | ".join(row))
'

  write_file "$LOCAL_BIN/cleanup-downloads" '#!/usr/bin/env bash
# Organize ~/Downloads by file type. Dry-run by default.
set -euo pipefail
APPLY=0
DOWNLOADS="${DOWNLOADS:-$HOME/Downloads}"
while (($#)); do
  case "$1" in
    --apply) APPLY=1 ;;
    --dry-run) APPLY=0 ;;
    --downloads) shift; DOWNLOADS="${1:?missing path}" ;;
    -h|--help) echo "usage: cleanup-downloads [--apply] [--downloads DIR]"; exit 0 ;;
    *) echo "unknown option: $1" >&2; exit 2 ;;
  esac
  shift
done
run(){ if (( APPLY )); then "$@"; else printf "[DRY RUN] "; printf "%q " "$@"; printf "\n"; fi; }
move_ext(){
  local dest="$1"; shift
  run mkdir -p "$DOWNLOADS/$dest"
  find "$DOWNLOADS" -maxdepth 1 -type f \( "$@" \) -print0 | while IFS= read -r -d "" f; do
    run mv -v "$f" "$DOWNLOADS/$dest/"
  done
}
move_ext pdf     -iname "*.pdf"
move_ext images  -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.gif" -o -iname "*.webp" -o -iname "*.svg" -o -iname "*.heic" -o -iname "*.avif"
