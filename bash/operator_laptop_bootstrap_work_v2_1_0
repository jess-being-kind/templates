# Create a structured engineering project.
mkproj() {
  if [[ $# -lt 1 ]]; then echo "usage: mkproj <project-name>"; return 1; fi
  local p="$ENGINEERING_DIR/projects/active/$1"
  mkdir -p "$p"/{src,scripts,tests,config,data/raw,data/processed,data/synthetic,docs,notes,logs,output/figures,output/tables,output/reports,sandbox}
  if [[ ! -f "$p/README.md" ]]; then
    printf "# %s\n\n## Mission\n\n## System Under Test\n\n## Interfaces\n\n## Tests\n\n## Data / Evidence\n\n## Next Actions\n\n" "$1" > "$p/README.md"
  fi
  cd "$p" || return
}

# Open or create today's operator log folder.
todaylog() {
  local d; d="$(date +%Y-%m-%d)"
  local p="$ENGINEERING_DIR/logs/$d"
  mkdir -p "$p"
  if [[ ! -f "$p/operator_log.md" ]]; then
    printf "# %s — Operator Log\n\n## Topline\n- Energy:\n- Focus:\n- Main mission:\n\n## Work Blocks\n| Time | Mission | Result |\n|---|---|---|\n| | | |\n\n## Notes / Signals\n- \n\n## Shutdown\n- What changed?\n- Next physical action?\n" "$d" > "$p/operator_log.md"
  fi
  cd "$p" || return
}

# Make one quick dated note in fieldNotes.
fieldnote() {
  local name="${1:-note}"
  local ts; ts="$(date +%Y%m%d_%H%M%S)"
  local p="$ENGINEERING_DIR/fieldNotes/${ts}_${name}.md"
  mkdir -p "$(dirname "$p")"
  printf "# %s — %s\n\n## Observation\n- \n\n## Evidence\n- \n\n## Next check\n- \n" "$ts" "$name" > "$p"
  ${EDITOR:-vim} "$p"
}

glados() {
  local text="${1:?usage: glados <text>}"
  builtin cd "$ENGINEERING_DIR/projects/active/GLaDOSTTS/src/GLaDOS" || return
  uv run glados say "$text"
  builtin cd - >/dev/null || return
}

