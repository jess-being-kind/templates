EOF
}
setup_system_theme(){
  info "Applying Halcyon-dark app/system preference layer"

  # GTK settings files influence many Linux desktop apps. They are safe text files
  # and do not require the target theme package to be installed.
  write_file_stream "$HOME/.config/gtk-3.0/settings.ini" <<'EOF'
[Settings]
gtk-application-prefer-dark-theme=1
gtk-theme-name=Mint-Y-Dark
gtk-icon-theme-name=Mint-Y-Sand
gtk-font-name=Sans 10
gtk-cursor-theme-size=24
EOF

  write_file_stream "$HOME/.config/gtk-4.0/settings.ini" <<'EOF'
[Settings]
gtk-application-prefer-dark-theme=1
gtk-theme-name=Mint-Y-Dark
gtk-icon-theme-name=Mint-Y-Sand
gtk-font-name=Sans 10
gtk-cursor-theme-size=24
EOF

  # Xresources is useful for older X11-aware apps and some terminal tools.
  write_file_stream "$HOME/.Xresources" <<EOF
! Halcyon dark Xresources
*.background: $HALCYON_BG
*.foreground: $HALCYON_FG
*.cursorColor: $HALCYON_GOLD
*.color0:  #1b1b1b
*.color1:  $HALCYON_RED
*.color2:  $HALCYON_GREEN
*.color3:  $HALCYON_GOLD
*.color4:  $HALCYON_BLUE
*.color5:  $HALCYON_PURPLE
*.color6:  $HALCYON_CYAN
*.color7:  $HALCYON_FG
*.color8:  #5c6370
*.color9:  #d98f84
*.color10: #a3be8c
*.color11: #e8c16a
*.color12: #8fb7d6
*.color13: #c7a0d9
*.color14: #9bd3df
*.color15: #fff4df
EOF

  # Live desktop preference changes. These are optional because schemas vary
  # between GNOME, Cinnamon, Mint, Xfce, etc. Failures are non-fatal.
  if (( APPLY_SYSTEM_THEME )); then
    if have_cmd gsettings; then
      run_optional gsettings set org.gnome.desktop.interface color-scheme prefer-dark
      run_optional gsettings set org.gnome.desktop.interface gtk-theme Mint-Y-Dark
      run_optional gsettings set org.gnome.desktop.interface icon-theme Mint-Y-Sand
      run_optional gsettings set org.cinnamon.desktop.interface gtk-theme Mint-Y-Dark
      run_optional gsettings set org.cinnamon.desktop.interface icon-theme Mint-Y-Sand
    else
      warn "gsettings not found; wrote GTK config files only."
    fi
  else
    warn "Skipping live system theme commands because --no-system-theme was set."
  fi
}

setup_mplstyle(){
  info "Creating matplotlib Halcyon-dark style"

  write_file_stream "$HOME/.config/matplotlib/stylelib/halcyon-dark.mplstyle" <<EOF
# halcyon-dark matplotlib style
# Use in Python with:
#   import matplotlib.pyplot as plt
#   plt.style.use('halcyon-dark')

figure.facecolor: $HALCYON_BG
axes.facecolor: $HALCYON_BG
axes.edgecolor: $HALCYON_MUTED
axes.labelcolor: $HALCYON_FG
axes.titlecolor: $HALCYON_GOLD
xtick.color: $HALCYON_FG
ytick.color: $HALCYON_FG
text.color: $HALCYON_FG
grid.color: #2a3140
grid.alpha: 0.45
axes.grid: True
legend.facecolor: $HALCYON_PANEL
legend.edgecolor: $HALCYON_MUTED
savefig.facecolor: $HALCYON_BG
savefig.edgecolor: $HALCYON_BG
lines.linewidth: 2.0
patch.edgecolor: $HALCYON_BG
image.cmap: inferno
axes.prop_cycle: cycler('color', ['$HALCYON_GOLD', '$HALCYON_BLUE', '$HALCYON_GREEN', '$HALCYON_RED', '$HALCYON_CYAN', '$HALCYON_PURPLE', '$HALCYON_AMBER'])
EOF
}

# ==============================================================================
# S7: Shell helpers and Bash quality-of-life layer
# ==============================================================================

setup_shell(){
  info "Creating shell helpers"

  # This file is generated and safe to replace with --force. It uses normal folder
  # names under ~/Vec/Engineering and keeps aliases/functions non-destructive.
  write_file_stream "$HOME/.operator_aliases" <<'EOF'
# ~/.operator_aliases
# Generated by operator_laptop_bootstrap.
# Purpose: interactive shell behavior, prompt, aliases, and Halcyon colors.
# Safe to edit, but rerunning bootstrap with --force will back it up.

# -----------------------------------------------------------------------------
# S0. Guardrails / tiny interactive helpers
# -----------------------------------------------------------------------------

# Pull in shared Halcyon colors for prompt/scripts/tools.
[[ -f "$HOME/.config/halcyon/colors.env" ]] && source "$HOME/.config/halcyon/colors.env"

# Let Ctrl+S be used by readline instead of terminal flow-control freeze.
stty -ixon 2>/dev/null || true

# Core paths. These resolve under ~/Vec by default but can be overridden before sourcing.
export VEC_ROOT="${VEC_ROOT:-$HOME/Vec}"
export ENGINEERING_DIR="${ENGINEERING_DIR:-$VEC_ROOT/Engineering}"
export VAULT_DIR="${VAULT_DIR:-$VEC_ROOT/Vaults/Work}"

path_prepend() {
  local dir="${1:?path_prepend requires a directory}"
  [[ -d "$dir" ]] || return 0
  case ":$PATH:" in
    *":$dir:"*) ;;
    *) export PATH="$dir:$PATH" ;;
  esac
}

path_prepend "$HOME/.local/bin"
path_prepend "$HOME/bin"
path_prepend "$ENGINEERING_DIR/bin"
path_prepend "$ENGINEERING_DIR/scripts"

# Editor / pager / Python defaults.
export EDITOR="${EDITOR:-vim}"
export VISUAL="${VISUAL:-$EDITOR}"
export PAGER="${PAGER:-less}"
export LESS="${LESS:--FRX}"
export PYTHONUNBUFFERED=1
export PYTHONDONTWRITEBYTECODE=1

# Keep terminal history useful across multiple open terminals.
export HISTSIZE=20000
export HISTFILESIZE=50000
export HISTCONTROL=ignoreboth:erasedups
export HISTTIMEFORMAT='%F %T  '
shopt -s histappend 2>/dev/null || true
__halcyon_history_sync='history -a; history -n'
if [[ -n "${PROMPT_COMMAND:-}" ]]; then
  case ";${PROMPT_COMMAND};" in
    *";${__halcyon_history_sync};"*) ;;
    *) PROMPT_COMMAND="${__halcyon_history_sync}; ${PROMPT_COMMAND}" ;;
  esac
else
  PROMPT_COMMAND="${__halcyon_history_sync}"
fi
unset __halcyon_history_sync

# -----------------------------------------------------------------------------
# S1. Halcyon soot/amber/signal-blue/moss color layer
# -----------------------------------------------------------------------------

# Hex fallbacks if colors.env was not created yet.
export HALCYON_SOOT="${HALCYON_SOOT:-#07090D}"
export HALCYON_SOOT_ALT="${HALCYON_SOOT_ALT:-#0B1118}"
export HALCYON_PANEL="${HALCYON_PANEL:-#11151C}"
export HALCYON_TEXT="${HALCYON_TEXT:-#F2E8D5}"
export HALCYON_MUTED="${HALCYON_MUTED:-#9AA0AA}"
export HALCYON_AMBER="${HALCYON_AMBER:-#FFBF00}"
export HALCYON_BRASS="${HALCYON_BRASS:-#B88746}"
export HALCYON_SIGNAL_BLUE="${HALCYON_SIGNAL_BLUE:-#4FA3B8}"
export HALCYON_MOSS="${HALCYON_MOSS:-#8FA37A}"
export HALCYON_RUST="${HALCYON_RUST:-#B7410E}"

# Compatibility aliases for scripts that use older token names.
export HALCYON_BG="${HALCYON_BG:-$HALCYON_SOOT}"
export HALCYON_BG_ALT="${HALCYON_BG_ALT:-$HALCYON_SOOT_ALT}"
export HALCYON_FG="${HALCYON_FG:-$HALCYON_TEXT}"
export HALCYON_GOLD="${HALCYON_GOLD:-$HALCYON_AMBER}"
export HALCYON_BLUE="${HALCYON_BLUE:-$HALCYON_SIGNAL_BLUE}"
export HALCYON_GREEN="${HALCYON_GREEN:-$HALCYON_MOSS}"
export HALCYON_RED="${HALCYON_RED:-$HALCYON_RUST}"

# 256-color ANSI approximations.
export HALCYON_ANSI_SOOT="${HALCYON_ANSI_SOOT:-232}"
export HALCYON_ANSI_PANEL="${HALCYON_ANSI_PANEL:-233}"
export HALCYON_ANSI_TEXT="${HALCYON_ANSI_TEXT:-230}"
export HALCYON_ANSI_AMBER="${HALCYON_ANSI_AMBER:-214}"
export HALCYON_ANSI_BRASS="${HALCYON_ANSI_BRASS:-172}"
export HALCYON_ANSI_SIGNAL_BLUE="${HALCYON_ANSI_SIGNAL_BLUE:-39}"
export HALCYON_ANSI_MOSS="${HALCYON_ANSI_MOSS:-107}"
export HALCYON_ANSI_RUST="${HALCYON_ANSI_RUST:-166}"

# Prompt/readline-safe escape helpers.
__hc_reset='\[\e[0m\]'
__hc_text="\[\e[38;5;${HALCYON_ANSI_TEXT}m\]"
__hc_amber="\[\e[38;5;${HALCYON_ANSI_AMBER}m\]"
__hc_blue="\[\e[38;5;${HALCYON_ANSI_SIGNAL_BLUE}m\]"
__hc_moss="\[\e[38;5;${HALCYON_ANSI_MOSS}m\]"

# Chroot-only prompt: no user@host:path. Defaults to debian-chroot when unset.
