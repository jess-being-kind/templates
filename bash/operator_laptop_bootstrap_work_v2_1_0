setup_halcyon_color_tokens(){
  info "Writing Halcyon-dark color tokens"

  write_file_stream "$HALCYON_CONFIG_DIR/colors.env" <<EOF
# Halcyon dark palette for shell/scripts/tools.
# Source from Bash with:
#   [[ -f "\$HOME/.config/halcyon/colors.env" ]] && source "\$HOME/.config/halcyon/colors.env"

export HALCYON_THEME="halcyon-dark"

# Canonical aesthetic tokens.
export HALCYON_SOOT="$HALCYON_SOOT"
export HALCYON_SOOT_ALT="$HALCYON_SOOT_ALT"
export HALCYON_PANEL="$HALCYON_PANEL"
export HALCYON_TEXT="$HALCYON_TEXT"
export HALCYON_MUTED="$HALCYON_MUTED"
export HALCYON_AMBER="$HALCYON_AMBER"
export HALCYON_BRASS="$HALCYON_BRASS"
export HALCYON_SIGNAL_BLUE="$HALCYON_SIGNAL_BLUE"
export HALCYON_MOSS="$HALCYON_MOSS"
export HALCYON_RUST="$HALCYON_RUST"
export HALCYON_MAROON="$HALCYON_MAROON"
export HALCYON_CYAN="$HALCYON_CYAN"
export HALCYON_PURPLE="$HALCYON_PURPLE"

# Compatibility aliases for older scripts/configs.
