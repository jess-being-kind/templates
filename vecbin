#!/usr/bin/env bash
# vecbin
#
# Symlink an executable/script into ~/.local/bin so it can be called from anywhere.
# This helper intentionally applies by default because the command name implies action.
# Use --dry-run to preview and --force to replace an existing command link.

set -Eeuo pipefail
IFS=$'\n\t'

VERSION="3.0.0"
AUTHOR="V Halcyon"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
RUN_ID="$(date -u +"%Y%m%d_%H%M%S_UTC")"

APPLY=1
FORCE=0
VERBOSE=0
BIN_DIR="${VECBIN_DIR:-${HOME}/.local/bin}"
VEC_ROOT="${VEC_ROOT:-${HOME}/Vec}"
ENGINEERING_DIR="${ENGINEERING_DIR:-${VEC_ROOT}/Engineering}"
MANIFEST_DIR="${VECBIN_MANIFEST_DIR:-${ENGINEERING_DIR}/logs/vecbin}"
SRC=""
NAME=""

log()   { printf "\033[1;32m[OK]\033[0m %s\n" "$*"; }
info()  { printf "\033[1;34m[INFO]\033[0m %s\n" "$*"; }
warn()  { printf "\033[1;33m[WARN]\033[0m %s\n" "$*" >&2; }
err()   { printf "\033[1;31m[ERR]\033[0m %s\n" "$*" >&2; }
debug() { (( VERBOSE )) && printf "\033[0;36m[DEBUG]\033[0m %s\n" "$*" >&2 || true; }
die() { err "$*"; exit 1; }

run_cmd() {
    if (( APPLY )); then
        debug "RUN: $(printf '%q ' "$@")"
        "$@"
    else
        printf "[DRY RUN] "
        printf "%q " "$@"
        printf "\n"
    fi
}

usage() {
    cat <<USAGE
Usage: $SCRIPT_NAME [options] <source-file> [command-name]

Options:
  --force, -f     Replace existing destination after backup.
  --dry-run       Preview without changing anything.
  --bin-dir DIR   Destination command directory. Default: $BIN_DIR
  -v, --verbose   Debug logging.
  --version       Print version.
  -h, --help      Show help.

Examples:
  vecbin ./plot.py plot.py
  vecbin --force ~/Vec/Engineering/scripts/plot.py plot
USAGE
}

parse_args() {
    while (($#)); do
        case "$1" in
            --force|-f) FORCE=1 ;;
            --dry-run|--no-load-run) APPLY=0 ;;
            --apply) APPLY=1 ;;
            --bin-dir) shift || die "missing value for --bin-dir"; BIN_DIR="${1:?missing value}" ;;
            -v|--verbose) VERBOSE=1 ;;
            --version) printf "%s\n" "$VERSION"; exit 0 ;;
            -h|--help) usage; exit 0 ;;
            --) shift; break ;;
            -*) die "unknown option: $1" ;;
            *)
                if [[ -z "$SRC" ]]; then SRC="$1"; elif [[ -z "$NAME" ]]; then NAME="$1"; else die "too many arguments: $1"; fi
                ;;
        esac
        shift
    done
}

main() {
    parse_args "$@"
    [[ -n "$SRC" ]] || { usage >&2; exit 2; }
    [[ -e "$SRC" ]] || die "source does not exist: $SRC"

    local src_abs dest backup
    src_abs="$(realpath "$SRC")"
    NAME="${NAME:-$(basename "$src_abs")}"
    NAME="${NAME// /_}"
    dest="${BIN_DIR}/${NAME}"

    run_cmd mkdir -p "$BIN_DIR" "$MANIFEST_DIR"

    case ":$PATH:" in
        *":$BIN_DIR:"*) ;;
        *) warn "$BIN_DIR is not currently on PATH for this shell" ;;
    esac

    if [[ -e "$dest" || -L "$dest" ]]; then
        if (( ! FORCE )); then
            die "destination exists: $dest  Use --force to replace."
        fi
        backup="${dest}.bak.${RUN_ID}"
        run_cmd cp -a "$dest" "$backup"
        run_cmd rm -f "$dest"
    fi

    run_cmd chmod +x "$src_abs"
    run_cmd ln -s "$src_abs" "$dest"

    if (( APPLY )); then
        cat > "${MANIFEST_DIR}/vecbin_${RUN_ID}.txt" <<MANIFEST
version=$VERSION
timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
source=$src_abs
destination=$dest
force=$FORCE
MANIFEST
    fi

    log "Linked: $dest -> $src_abs"
}

main "$@"
